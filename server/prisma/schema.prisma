generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────

enum UserRole {
  ADMIN
  STAFF
  VIEWER
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum PaymentTerms {
  IMMEDIATE
  NET_30
  NET_60
  NET_90
}

enum PlasticMaterial {
  PET
  HDPE
  PP
  PVC
  PS
  ABS
}

enum ProductColor {
  TRANSPARENT
  WHITE
  CUSTOM
}

enum ProductShape {
  ROUND
  SQUARE
  OVAL
  FLAT
}

enum NeckType {
  WIDE
  NARROW
  PUMP
  SPRAY
  SCREW
}

enum UnitOfSale {
  PIECE
  CARTON
  KG
}

enum Industry {
  FOOD
  COSMETICS
  CHEMICAL
  PHARMA
  HOUSEHOLD
}

enum SafetyStandard {
  FDA_FOOD_GRADE
  BPA_FREE
  ISO
}

enum SalesOrderStatus {
  DRAFT
  PENDING
  NEW
  CONFIRMED
  PREPARING
  SHIPPING
  INVOICED
  COMPLETED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  NEW
  CONFIRMED
  PROCESSING
  SHIPPING
  INVOICED
  COMPLETED
  CANCELLED
}

enum DebtStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  OTHER
}

enum VATRate {
  VAT_0
  VAT_8
  VAT_10
}

enum EmploymentStatus {
  ACTIVE
  PROBATION
  INACTIVE
}

enum PayrollPeriodStatus {
  DRAFT
  CALCULATED
  APPROVED
  PAID
}

// ─── USERS ──────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  full_name     String
  role          UserRole @default(STAFF)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  employee_profile EmployeeProfile?

  @@map("users")
}

// ─── PAYROLL ────────────────────────────────────────

model EmployeeProfile {
  id                String           @id @default(uuid())
  user_id           String           @unique
  base_salary       Float            @default(0)
  meal_allowance    Float            @default(0)
  phone_allowance   Float            @default(0)
  fuel_allowance    Float            @default(0)
  dependents        Int              @default(0)
  insurance_number  String?
  tax_code          String?
  bank_account      String?
  bank_name         String?
  employment_status EmploymentStatus @default(ACTIVE)
  join_date         DateTime         @default(now())
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  user    User            @relation(fields: [user_id], references: [id])
  records PayrollRecord[]

  @@map("employee_profiles")
}

model PayrollConfig {
  id                  String   @id @default(uuid())
  base_salary_cap     Float    @default(36000000)
  personal_deduction  Float    @default(11000000)
  dependent_deduction Float    @default(4400000)
  bhxh_employee       Float    @default(8)
  bhxh_employer       Float    @default(17.5)
  bhyt_employee       Float    @default(1.5)
  bhyt_employer       Float    @default(3)
  bhtn_employee       Float    @default(1)
  bhtn_employer       Float    @default(1)
  meal_cap            Float    @default(730000)
  phone_cap           Float    @default(1000000)
  fuel_cap            Float    @default(2000000)
  effective_from      DateTime @default(now())
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@map("payroll_configs")
}

model PayrollPeriod {
  id          String              @id @default(uuid())
  year        Int
  month       Int
  status      PayrollPeriodStatus @default(DRAFT)
  notes       String?
  created_by  String?
  approved_by String?
  approved_at DateTime?
  paid_at     DateTime?
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt

  records PayrollRecord[]

  @@unique([year, month])
  @@map("payroll_periods")
}

model PayrollRecord {
  id                       String           @id @default(uuid())
  period_id                String
  employee_id              String
  // Snapshot
  base_salary              Float
  meal_allowance           Float
  phone_allowance          Float
  fuel_allowance           Float
  dependents               Int
  employment_status        EmploymentStatus
  // Calculated
  gross_salary             Float
  insurance_base           Float
  bhxh_employee            Float
  bhyt_employee            Float
  bhtn_employee            Float
  total_insurance_employee Float
  bhxh_employer            Float
  bhyt_employer            Float
  bhtn_employer            Float
  total_insurance_employer Float
  tax_free_allowances      Float
  personal_deduction       Float
  dependent_deduction      Float
  taxable_income           Float
  pit                      Float
  net_salary               Float
  created_at               DateTime         @default(now())
  updated_at               DateTime         @updatedAt

  period   PayrollPeriod   @relation(fields: [period_id], references: [id])
  employee EmployeeProfile @relation(fields: [employee_id], references: [id])

  @@unique([period_id, employee_id])
  @@map("payroll_records")
}

// ─── AUDIT LOG ──────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String?
  user_name  String?
  action     String   // CREATE, UPDATE, DELETE
  model_name String   // SalesOrder, Customer, etc.
  record_id  String?
  old_data   Json?
  new_data   Json?
  ip_address String?
  created_at DateTime @default(now())

  @@index([model_name, record_id])
  @@index([user_id, created_at])
  @@map("audit_logs")
}

// ─── CATEGORIES ─────────────────────────────────────

model Category {
  id        String  @id @default(uuid())
  name      String
  parent_id String?
  sort_order Int    @default(0)
  is_active Boolean @default(true)

  parent   Category?  @relation("CategoryTree", fields: [parent_id], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

// ─── PRODUCTS ───────────────────────────────────────

model Product {
  id          String          @id @default(uuid())
  sku         String          @unique
  name        String
  category_id String?
  description String?

  // Technical specs
  material      PlasticMaterial?
  capacity_ml   Float?
  height_mm     Float?
  body_dia_mm   Float?
  neck_dia_mm   Float?
  weight_g      Float?
  color         ProductColor?
  custom_color  String?
  shape         ProductShape?
  neck_type     NeckType?
  neck_spec     String?

  // Packaging
  unit_of_sale    UnitOfSale @default(PIECE)
  pcs_per_carton  Int?
  carton_weight   Float?
  carton_length   Float?
  carton_width    Float?
  carton_height   Float?

  // Application
  industries      Industry[]
  safety_standards SafetyStandard[]

  // Pricing
  moq             Int?
  retail_price    Float?
  wholesale_price Float?

  // Media
  catalog_pdf_url String?

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  category          Category?          @relation(fields: [category_id], references: [id])
  images            ProductImage[]
  price_tiers       PriceTier[]
  supplier_prices   SupplierPrice[]
  sales_order_items    SalesOrderItem[]
  purchase_order_items PurchaseOrderItem[]
  sales_return_items   SalesReturnItem[]
  purchase_return_items PurchaseReturnItem[]

  aliases           ProductAlias[]

  @@map("products")
}

// Tên khách gọi cho sản phẩm (VD: "chai xanh 500" → PET-500)
model ProductAlias {
  id         String   @id @default(uuid())
  product_id String
  alias      String   // Tên khách gọi
  created_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id])

  @@unique([product_id, alias])
  @@index([alias])
  @@map("product_aliases")
}

model ProductImage {
  id         String  @id @default(uuid())
  product_id String
  url        String
  public_id  String?
  is_primary Boolean @default(false)
  sort_order Int     @default(0)

  product Product @relation(fields: [product_id], references: [id])

  @@map("product_images")
}

model PriceTier {
  id         String @id @default(uuid())
  product_id String
  min_qty    Int
  price      Float

  product Product @relation(fields: [product_id], references: [id])

  @@map("price_tiers")
}

// ─── CUSTOMERS ──────────────────────────────────────

// ─── CUSTOMERS ──────────────────────────────────────

model Customer {
  id           String       @id @default(uuid())
  company_name String
  tax_code     String?
  address      String?
  contact_name String?
  phone        String?
  email        String?
  customer_type CustomerType @default(INDIVIDUAL)
  debt_limit   Float        @default(0)
  zalo_user_id String?      // Phase 2
  approval_status String    @default("APPROVED") // PENDING, APPROVED
  is_active    Boolean      @default(true)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  sales_orders  SalesOrder[]
  receivables   Receivable[]
  sales_returns SalesReturn[]

  @@map("customers")
}

// ─── SUPPLIERS ──────────────────────────────────────

model Supplier {
  id            String       @id @default(uuid())
  company_name  String
  tax_code      String?
  address       String?
  contact_name  String?
  phone         String?
  email         String?
  payment_terms PaymentTerms @default(NET_30)
  zalo_user_id  String?      // Phase 2
  is_active     Boolean      @default(true)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  supplier_prices    SupplierPrice[]
  purchase_orders    PurchaseOrder[]
  payables           Payable[]
  sales_order_items  SalesOrderItem[]
  purchase_returns   PurchaseReturn[]

  @@map("suppliers")
}

model SupplierPrice {
  id              String  @id @default(uuid())
  supplier_id     String
  product_id      String
  purchase_price  Float
  moq             Int?
  lead_time_days  Int?
  stock_quantity  Int     @default(0)  // Tồn kho bên NCC
  is_preferred    Boolean @default(false)
  updated_at      DateTime @default(now()) @updatedAt

  supplier Supplier @relation(fields: [supplier_id], references: [id])
  product  Product  @relation(fields: [product_id], references: [id])

  @@unique([supplier_id, product_id])
  @@map("supplier_prices")
}

// ─── SALES ORDERS ───────────────────────────────────

model SalesOrder {
  id                  String           @id @default(uuid())
  order_code          String           @unique
  customer_id         String
  order_date          DateTime         @default(now())
  expected_delivery   DateTime?
  notes               String?
  subtotal            Float            @default(0)
  discount_amount     Float            @default(0)
  vat_rate            VATRate          @default(VAT_0)
  vat_amount          Float            @default(0)
  shipping_fee        Float            @default(0)
  other_fee           Float            @default(0)
  other_fee_note      String?
  grand_total         Float            @default(0)
  status              SalesOrderStatus @default(DRAFT)
  zalo_message_id     String?          // Phase 2
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  customer        Customer         @relation(fields: [customer_id], references: [id])
  items           SalesOrderItem[]
  purchase_orders PurchaseOrder[]
  receivables     Receivable[]
  invoices        Invoice[]
  sales_returns   SalesReturn[]

  @@map("sales_orders")
}

model SalesOrderItem {
  id             String  @id @default(uuid())
  sales_order_id String
  product_id     String?
  supplier_id    String?            // NCC cung cấp SP này
  quantity       Int
  unit_price     Float              // Giá bán cho khách
  purchase_price Float?             // Giá mua từ NCC
  discount_pct   Float   @default(0)
  vat_rate       Int     @default(0)    // VAT % per item (0, 8, 10)
  line_total     Float                  // = qty * unit_price * (1 - discount_pct/100)
  vat_amount     Float   @default(0)    // = line_total * vat_rate / 100
  customer_product_name String? // Tên SP khách gọi (VD: "chai xanh 500")
  color_note     String?
  packaging_note String?
  supplier_status String @default("PENDING") // PENDING, CONFIRMED, SHIPPING, DELIVERED

  sales_order SalesOrder    @relation(fields: [sales_order_id], references: [id])
  product     Product?      @relation(fields: [product_id], references: [id])
  supplier    Supplier?     @relation(fields: [supplier_id], references: [id])

  @@map("sales_order_items")
}

// ─── PURCHASE ORDERS ────────────────────────────────

model PurchaseOrder {
  id                 String              @id @default(uuid())
  order_code         String              @unique
  sales_order_id     String?             // Linked to SO (required for new flow)
  supplier_id        String
  order_date         DateTime            @default(now())
  expected_delivery  DateTime?
  notes              String?
  total              Float               @default(0)
  shipping_fee       Float               @default(0)
  other_fee          Float               @default(0)
  other_fee_note     String?
  status             PurchaseOrderStatus @default(DRAFT)
  zalo_message_id    String?
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt

  sales_order      SalesOrder?         @relation(fields: [sales_order_id], references: [id])
  supplier         Supplier            @relation(fields: [supplier_id], references: [id])
  items            PurchaseOrderItem[]
  payables         Payable[]
  invoices         Invoice[]
  purchase_returns PurchaseReturn[]

  @@index([sales_order_id])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String @id @default(uuid())
  purchase_order_id String
  product_id        String
  quantity          Int
  unit_price        Float
  line_total        Float

  purchase_order PurchaseOrder @relation(fields: [purchase_order_id], references: [id])
  product        Product       @relation(fields: [product_id], references: [id])

  @@map("purchase_order_items")
}

// ─── RECEIVABLES ────────────────────────────────────

model Receivable {
  id              String     @id @default(uuid())
  sales_order_id  String
  customer_id     String
  invoice_number  String?
  invoice_date    DateTime   @default(now())
  due_date        DateTime
  original_amount Float
  paid_amount     Float      @default(0)
  remaining       Float
  status          DebtStatus @default(UNPAID)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  sales_order SalesOrder        @relation(fields: [sales_order_id], references: [id])
  customer    Customer          @relation(fields: [customer_id], references: [id])
  payments    ReceivablePayment[]

  @@map("receivables")
}

model ReceivablePayment {
  id            String        @id @default(uuid())
  receivable_id String
  amount        Float
  payment_date  DateTime      @default(now())
  method        PaymentMethod @default(BANK_TRANSFER)
  reference     String?
  evidence_url  String?       // Ảnh/file minh chứng thanh toán
  created_at    DateTime      @default(now())

  receivable Receivable @relation(fields: [receivable_id], references: [id])

  @@map("receivable_payments")
}

// ─── PAYABLES ───────────────────────────────────────

model Payable {
  id                String     @id @default(uuid())
  purchase_order_id String
  supplier_id       String
  invoice_number    String?
  invoice_date      DateTime   @default(now())
  due_date          DateTime
  original_amount   Float
  paid_amount       Float      @default(0)
  remaining         Float
  status            DebtStatus @default(UNPAID)
  statement_url     String?    // uploaded supplier statement
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  purchase_order PurchaseOrder   @relation(fields: [purchase_order_id], references: [id])
  supplier       Supplier        @relation(fields: [supplier_id], references: [id])
  payments       PayablePayment[]

  @@map("payables")
}

model PayablePayment {
  id          String        @id @default(uuid())
  payable_id  String
  amount      Float
  payment_date DateTime     @default(now())
  method      PaymentMethod @default(BANK_TRANSFER)
  reference   String?
  evidence_url String?      // Ảnh/file minh chứng thanh toán
  created_at  DateTime      @default(now())

  payable Payable @relation(fields: [payable_id], references: [id])

  @@map("payable_payments")
}

// ─── OPERATING COSTS ────────────────────────────────

model OperatingCostCategory {
  id        String  @id @default(uuid())
  name      String  @unique
  is_active Boolean @default(true)

  costs OperatingCost[]

  @@map("operating_cost_categories")
}

model OperatingCost {
  id          String   @id @default(uuid())
  date        DateTime
  category_id String
  description String?
  amount      Float
  receipt_url String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  category OperatingCostCategory @relation(fields: [category_id], references: [id])

  @@map("operating_costs")
}

// ─── INVOICES ───────────────────────────────────────

model Invoice {
  id                 String        @id @default(uuid())
  type               String        @default("SALES") // SALES or PURCHASE
  sales_order_id     String?
  purchase_order_id  String?
  status             InvoiceStatus @default(DRAFT)
  serial             String        @default("1C26PKF")
  invoice_number     Int
  invoice_date       DateTime      @default(now())
  cqt_code           String?

  // Seller info (editable - for SALES invoice)
  seller_name      String?
  seller_tax_code  String?
  seller_address   String?
  seller_phone     String?
  seller_email     String?
  seller_rep       String?
  seller_position  String?
  seller_bank      String?
  seller_bank_name String?

  // Buyer info (editable - for SALES invoice)
  buyer_name       String?
  buyer_company    String?
  buyer_address    String?
  buyer_tax_code   String?
  buyer_phone      String?
  buyer_email      String?
  buyer_payment    String?       @default("Chuyển khoản")

  // Items & amounts (for SALES invoice)
  items            Json?         // [{name, unit, quantity, unitPrice, amount}]
  subtotal         Float?
  vat_rate         Int           @default(10)
  vat_amount       Float?
  total            Float?
  total_in_words   String?
  notes            String?

  // File upload (for PURCHASE invoice from supplier)
  file_url         String?       // Uploaded invoice file/image URL
  file_name        String?

  created_at       DateTime      @default(now())
  updated_at       DateTime      @default(now()) @updatedAt

  sales_order      SalesOrder?    @relation(fields: [sales_order_id], references: [id])
  purchase_order   PurchaseOrder? @relation(fields: [purchase_order_id], references: [id])

  @@index([sales_order_id])
  @@index([purchase_order_id])
  @@index([status])
  @@index([type])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  CANCELLED
}

enum CashTransactionType {
  INCOME
  EXPENSE
}

enum ReturnStatus {
  PENDING
  APPROVED
  RECEIVING
  SHIPPING
  COMPLETED
  REJECTED
  CANCELLED
}

// ─── ALERTS ─────────────────────────────────────────

model Alert {
  id              String   @id @default(uuid())
  type            String   // WARNING, URGENT, CRITICAL, ESCALATION
  title           String
  message         String
  purchase_order_id String?
  is_read         Boolean  @default(false)
  action_taken    String?  // CONFIRMED_DELAY, DELIVERED, etc.
  new_expected_date DateTime?
  created_at      DateTime @default(now())

  @@map("alerts")
}

// ─── SYSTEM CONFIG ──────────────────────────────────

model SystemConfig {
  id    String @id @default(uuid())
  key   String @unique
  value String // JSON string

  @@map("system_configs")
}

// ─── ZALO INTEGRATION ────────────────────────────────

model ZaloConfig {
  id                    String   @id @default(uuid())
  // FUNC_GET_THREADS
  get_threads_url       String?
  get_threads_token     String?
  // FUNC_GET_MESSAGES
  get_messages_url      String?
  get_messages_token    String?
  // GET_GROUP_INFO
  get_group_info_url    String?
  get_group_info_token  String?
  // GET_USER_INFO_V2
  get_user_info_url     String?
  get_user_info_token   String?
  // GET_USER_INFO_EXTRA
  get_user_extra_url    String?
  get_user_extra_token  String?
  // General
  account_token         String?
  webhook_secret        String?
  // AI Prompts
  ai_chat_prompt        String?  @db.Text
  ai_summary_prompt     String?  @db.Text
  ai_order_prompt       String?  @db.Text
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("zalo_configs")
}

model ZaloMessage {
  id            String   @id @default(uuid())
  direction     String   // INCOMING | OUTGOING
  platform      String   @default("ZALO_USER")
  account_id    String?
  sender_id     String?
  sender_name   String?
  recipient_id  String?
  group_id      String?
  msg_id        String?
  msg_type      String?  // webchat, group, etc.
  content       String?
  event         String?  // RECEIVED_MESSAGE, SENT_MESSAGE, etc.
  raw_payload   Json?
  status        String   @default("RECEIVED") // RECEIVED, SENT, FAILED
  created_at    DateTime @default(now())

  @@index([sender_id])
  @@index([created_at])
  @@map("zalo_messages")
}

model AiTraining {
  id          String   @id @default(uuid())
  category    String   // PRODUCT_ALIAS, ORDER_EXAMPLE, CORRECTION, BUSINESS_RULE, CUSTOMER_INFO
  title       String
  content     String   @db.Text
  is_active   Boolean  @default(true)
  created_by  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([category])
  @@map("ai_trainings")
}

model AiChatMessage {
  id         String   @id @default(uuid())
  user_id    String
  role       String   // user, ai
  content    String   @db.Text
  created_at DateTime @default(now())

  @@index([user_id, created_at])
  @@map("ai_chat_messages")
}

model OrderSuggestion {
  id              String   @id @default(uuid())
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  sender_id       String
  sender_name     String
  message         String   @db.Text
  ai_summary      String?  @db.Text
  customer_name   String?
  customer_phone  String?
  delivery_note   String?
  extracted_items Json?    // [{product_name, quantity, unit_price, note}]
  matched_items   Json?    // [{product_id, product_name, quantity, unit_price}]
  sales_order_id  String?  // filled after approval
  rejected_reason String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([status, created_at])
  @@map("order_suggestions")
}

// ─── RETURNS ───────────────────────────────────────

model SalesReturn {
  id              String       @id @default(uuid())
  return_code     String       @unique
  sales_order_id  String
  customer_id     String
  return_date     DateTime     @default(now())
  total_amount    Float        @default(0)
  reason          String?
  notes           String?
  status          ReturnStatus @default(PENDING)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  sales_order SalesOrder      @relation(fields: [sales_order_id], references: [id])
  customer    Customer        @relation(fields: [customer_id], references: [id])
  items       SalesReturnItem[]

  @@index([sales_order_id])
  @@index([customer_id])
  @@map("sales_returns")
}

model SalesReturnItem {
  id              String  @id @default(uuid())
  sales_return_id String
  product_id      String
  quantity        Int
  unit_price      Float
  line_total      Float
  reason          String?

  sales_return SalesReturn @relation(fields: [sales_return_id], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [product_id], references: [id])

  @@map("sales_return_items")
}

model PurchaseReturn {
  id                 String       @id @default(uuid())
  return_code        String       @unique
  purchase_order_id  String
  supplier_id        String
  return_date        DateTime     @default(now())
  total_amount       Float        @default(0)
  reason             String?
  notes              String?
  status             ReturnStatus @default(PENDING)
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt

  purchase_order PurchaseOrder      @relation(fields: [purchase_order_id], references: [id])
  supplier       Supplier           @relation(fields: [supplier_id], references: [id])
  items          PurchaseReturnItem[]

  @@index([purchase_order_id])
  @@index([supplier_id])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id                  String  @id @default(uuid())
  purchase_return_id  String
  product_id          String
  quantity            Int
  unit_price          Float
  line_total          Float
  reason              String?

  purchase_return PurchaseReturn @relation(fields: [purchase_return_id], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [product_id], references: [id])

  @@map("purchase_return_items")
}

// ─── CASH BOOK (SỔ QUỸ) ───────────────────────────

model CashCategory {
  id          String  @id @default(uuid())
  name        String
  type        CashTransactionType  // INCOME or EXPENSE
  is_active   Boolean @default(true)
  created_at  DateTime @default(now())

  transactions CashTransaction[]

  @@map("cash_categories")
}

model CashTransaction {
  id            String              @id @default(uuid())
  type          CashTransactionType
  category_id   String
  date          DateTime            @default(now())
  amount        Float
  description   String
  reference     String?             // Mã tham chiếu (hoá đơn, chuyển khoản...)
  evidence_url  String?             // URL ảnh minh chứng (chuyển khoản, biên lai...)
  payment_method PaymentMethod      @default(CASH)
  notes         String?
  is_auto       Boolean             @default(false) // true = tự tạo từ thanh toán công nợ
  created_at    DateTime            @default(now())
  updated_at    DateTime            @updatedAt

  category CashCategory @relation(fields: [category_id], references: [id])

  @@index([type, date])
  @@map("cash_transactions")
}
