DATABASE_URL="postgresql://postgres:postgres@localhost:5432/packflow_crm"
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
DEFAULT_ADMIN_EMAIL=admin@packflow.vn
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_RECEIVABLE_DUE_DAYS=30

# Redis
REDIS_URL=redis://localhost:6379
REDIS_DEFAULT_TTL=300

# Rate Limiting
RATE_LIMIT_GLOBAL=500
RATE_LIMIT_AUTH=20
RATE_LIMIT_API=100
RATE_LIMIT_HEAVY=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_MAX_FILES=10

# Zalo / Func.vn
ZALO_FUNC_GET_THREADS_URL=https://public-api.func.vn/functions/your-function-id
ZALO_FUNC_GET_THREADS_TOKEN=your-token-here
ZALO_FUNC_GET_MESSAGES_URL=https://public-api.func.vn/functions/your-function-id
ZALO_FUNC_GET_MESSAGES_TOKEN=your-token-here
ZALO_FUNC_ACCOUNT_TOKEN=your-account-token-here
